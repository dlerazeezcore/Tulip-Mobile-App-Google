{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public and private user information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "notificationsEnabled": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "membershipLevel": { "type": "string", "enum": ["Basic", "Gold", "Diamond"] }
      },
      "required": ["uid", "createdAt"]
    },
    "Booking": {
      "title": "Travel Booking",
      "description": "Flight, hotel or eSIM booking record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "serviceType": { "type": "string", "enum": ["flights", "hotels", "esim"] },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "details": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "serviceType", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Basic user profiles"
    },
    "/users/{userId}/private/info": {
      "schema": "User",
      "description": "Isolated PII for security"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "All travel bookings"
    }
  }
}
