rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---
    function isValidUser(data) {
      return data.uid == request.auth.uid 
          && (data.email == null || (data.email is string && data.email.size() <= 100))
          && (data.phoneNumber == null || (data.phoneNumber is string && data.phoneNumber.size() <= 20))
          && (data.displayName == null || (data.displayName is string && data.displayName.size() <= 100))
          && (data.notificationsEnabled == null || data.notificationsEnabled is bool)
          && data.createdAt is timestamp
          && data.updatedAt is timestamp;
    }

    function isValidBooking(data) {
      return data.userId == request.auth.uid
          && data.serviceType in ['flights', 'hotels', 'esim']
          && data.status in ['pending', 'confirmed', 'cancelled']
          && data.createdAt is timestamp
          && data.updatedAt is timestamp;
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Users cannot be listed
      
      allow create: if isSignedIn() && isOwner(userId) 
                    && isValidUser(incoming())
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time
                    && incoming().membershipLevel == 'Basic'; // Start at Basic
      
      allow update: if isSignedIn() && isOwner(userId)
                    && isValidUser(incoming())
                    && incoming().updatedAt == request.time
                    && incoming().uid == existing().uid
                    && incoming().createdAt == existing().createdAt
                    && (
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'email', 'notificationsEnabled', 'updatedAt'])
                    );
    }

    match /users/{userId}/private/info {
      allow read, write: if isOwner(userId);
    }

    match /bookings/{bookingId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
                    && isValidBooking(incoming())
                    && incoming().status == 'pending'
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time;
      
      allow update: if isSignedIn() 
                    && isValidBooking(incoming())
                    && incoming().userId == existing().userId
                    && incoming().createdAt == existing().createdAt
                    && incoming().updatedAt == request.time
                    && (
                      // Users can only cancel their own bookings
                      (incoming().status == 'cancelled' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']))
                    );
      
      allow delete: if false; // Deletion not allowed, use cancellation
    }
  }
}
